@using Database
@using WebApp.Utilities.Extensions
@using WebApp.Utilities.MenuAndRoles
@model IEnumerable<GTBirimler>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = (Kullanicilar)ViewBag.Kullanici;
    var yetkiliHesapNumalari = (List<KullaniciGTHesapNumaralari>)ViewBag.YetkiliHesapNumalari;
    var allchecked = (yetkiliHesapNumalari.Count == Model.SelectMany(s => s.GTBirimHesapNumaralaris).Count());
    var kullaniciKayit = RoleNames.KullaniciKayit.InRole();
}



<div class="row">

    <form method="post" id="kulSbmtFrm" class="form-horizontal" role="form">
        <div class="col-md-12 col-md-12 col-md-12">
            <div class="panel panel-default">
                <div class="portlet-title">
                    <div class="panel-heading padding-0">
                        <h3 class="panel-title"><i class="fa fa-list"></i>Gelir Takip Hesap Numaraları Yetkileri: @user.Ad @user.Soyad [@user.KullaniciAdi] </h3>

                        <ul class="panel-controls">
                            <li>
                                Tümü:<div class="make-switch switch-small" data-on-label="Evet" data-off-label="Hayır" style="z-index:0">
                                    <input type="checkbox" value="true" id="tmunusec" onchange="tumunusec(this)" class="toggle" @allchecked.ToChecked() />
                                </div>
                            </li>
                            @if (kullaniciKayit)
                            {
                                <li><span class="label label-info label-form" onclick="window.location.href='@Url.Action("Kayit", new { id = user.KullaniciID })'" style="cursor:pointer;"><i class="fa fa-user"></i> Kullanıcı</span></li>
                                <li><span class="label label-info label-form" onclick="window.location.href='@Url.Action("KullaniciBirimYetkileri", new { id = user.KullaniciID })'" style="cursor:pointer;"><i class="fa fa-home"></i> Birim Yetkileri</span></li>
                                <li><span class="label label-info label-form" onclick="window.location.href='@Url.Action("Yetkilendirme", new { id = user.KullaniciID })'" style="cursor:pointer;"><i class="fa fa-lock"></i> Erişim Yetkileri</span></li>
                                <li><span class="label label-info label-form" onclick="window.location.href='@Url.Action("KullaniciHesapKodYetkileri", new { id = user.KullaniciID })'" style="cursor:pointer;"><i class="fa fa-list"></i> Hesap Kod Yetkileri</span></li>
                            }


                            <li><a href="@Url.Action("KullaniciHesapNoYetkileri","Kullanicilar",new {id= user.KullaniciID })" class=""><span class="fa fa-refresh panel-refresh"></span></a></li>
                        </ul>
                    </div>
                </div>
                <div class="panel-body form">
                    <input type="hidden" name="KullaniciID" value="@user.KullaniciID" />

                    <table class="table" style="width:100%;table-layout:fixed;">
                        <thead>
                            <tr>
                                <th>Hesap Numarası Adı</th>
                            </tr>
                            <tr>
                                <td colspan="2">
                                    <table style="width: 100%;">
                                        <tr>
                                            <td>
                                                <div style="width: 100%;" class="checkbox pull-left">
                                                    <label style="width: 100%;">
                                                        <input style="color: red; width: 100%;" type="text" name="search" id="filterBInp" placeholder="ara..." class="form-control">
                                                    </label>
                                                </div>
                                            </td>
                                            <td></td>
                                        </tr>
                                    </table>

                                </td>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                <tr>
                                    <td colspan="2">
                                        <div style="overflow:auto;height:600px;">
                                            <table id="prgList" style="table-layout:fixed;width:100%;">
                                                @foreach (var item in Model)
                                                {

                                                    <tr class="_rows">
                                                        <td>

                                                            <label style="color:maroon;font-weight:bold;">
                                                                <span class="hkAdlari">@item.BirimAdi </span>
                                                            </label>

                                                        </td>
                                                    </tr>
                                                    foreach (var itemHk in item.GTBirimHesapNumaralaris)
                                                    {
                                                        var yetkiVar = yetkiliHesapNumalari.Any(a => a.GTBirimID == itemHk.GTBirimID && a.GTHesapNoID == itemHk.GTHesapNoID);
                                                        <tr class="_rows" @(yetkiVar ? "style=color:blue" : "")>
                                                            <td>
                                                                <input type="checkbox" style="width:13px;height:13px;cursor:pointer;" class="chkAll" name="GTHesapNoIDs" value="@(item.GTBirimID+"/"+itemHk.GTHesapNoID)" @yetkiVar.ToChecked()>
                                                                <span style="cursor:pointer;" onclick="$(this).prev().click()" class="hkAdlari">@itemHk.GTHesapNumaralari.HesapNo / @itemHk.GTHesapNumaralari.HesapNoAdi</span>
                                                            </td>
                                                        </tr>
                                                    }

                                                }
                                            </table>
                                        </div>
                                    </td>
                                </tr>

                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }
                            <tr>
                                <td id="filtreKelime" colspan="2"></td>
                            </tr>

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-reply"></i>Geri Dön</a>
                    <button class="btn btn-primary pull-right"><i class="fa fa-save"></i>Kaydet</button>
                    <input type="hidden" id="YetkilendirmeyeGit" name="YetkilendirmeyeGit" value="false" />

                </div>
            </div>
        </div>

    </form>
</div>
<script type="text/javascript">


    function tumunusec(sndr) {
        var chkD = $(sndr).prop("checked");
        $('.chkAll').each(function (inx, itmx) {
            if ($(itmx).parents('._rows').first().css('display') != "none") {
                $(itmx).prop("checked", chkD);
                $(itmx).prev().prop("checked", chkD);
            }
        });
    }
    function Filtrele() {
        var filtreval = $('#filterBInp').val().replace('İ', 'i').toLowerCase();
        var $fltrRow = $('._rows');

        if (filtreval != null && filtreval != "") {
            var toplam = $('._rows').length;
            $('#prgList').find('tr').each(function (inx, trx) {
                var _birimdi = $(trx).find(".hkAdlari").first().text();
                var clmValBol = _birimdi.replace('İ', 'i').toLowerCase();
                //var ipS = $(trx).find('.ipS').first().text().toLowerCase();
                var AShow = clmValBol.indexOf(filtreval) > -1;
                // var IShow = ipS.indexOf(filtreval) > -1;
                if (AShow) {
                    $(trx).removeClass("hide");
                }
                else {
                    $(trx).addClass("hide");
                }

            })
            var Gizli = $('._rows.hide').length;
            var gosterilen = toplam - Gizli;
            $('#filtreKelime').html("[Ara:  %<span style='color:red;'>" + filtreval + "</span>%] [Bulunan: <span style='color:red;'>" + gosterilen + "</span>]");

        }
        else {
            $fltrRow.removeClass("hide");
            $('#filtreKelime').html("");

        }
    }
    $('#filterBInp').bind("keydown", function (event) {
        if (event.keyCode == 13) {
            Filtrele();
            event.preventDefault();
        }
    });
</script>




