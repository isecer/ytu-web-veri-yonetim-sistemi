        function myMask(e, sndr, _isNumericOrDecimal, _maxLength, _firstLength, _lastLength) {
            var theEvent = e || window.event;
            var isNumericOrDecimal = _isNumericOrDecimal;
            var maxLength = _maxLength;
            var firstLength = _firstLength;
            var lastLength = _lastLength;
            // Allow: backspace, delete, tab, escape, enter and .
            if ($.inArray(e.keyCode, [46, 8, 9, 27, 13]) !== -1 ||
                // Allow: Ctrl+A
                (e.keyCode == 65 && e.ctrlKey === true) ||
                // Allow: home, end, left, right
                (e.keyCode >= 35 && e.keyCode <= 39)) {
                // let it happen, don't do anything
                return;
            }
            // Ensure that it is a number and stop the keypress
            if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105) && e.keyCode != 188 && e.keyCode != 190 && e.keyCode!=110) {
                e.preventDefault();
            }
            else {
                var impVal = $(sndr).val();
                var impLength = (impVal.length + 1);
                if (isNumericOrDecimal) {
                    if (e.keyCode == 188 || e.keyCode==190 || e.keyCode == 110) e.preventDefault();
                    else if (maxLength > 0) {
                        if (maxLength < impLength) e.preventDefault();
                    }

                }
                else {
                    if (e.keyCode == 188 || e.keyCode == 190 || e.keyCode == 110) {
                        if (impVal.replace('.',',').indexOf(",") >= 0 || impVal == "") e.preventDefault();

                    }
                    var imsplt = impVal.replace('.',',').split(',');
                    if (imsplt.length > 1) {

                        var maxLength = firstLength + lastLength + 1;
                        var frVOk = false;
                        var firstV = imsplt[0].length + 1;
                        if (firstLength < firstV) frVOk = true;
                        var frLVOk = false;
                        var flastV = imsplt[1].length + 1
                        if (lastLength < flastV) frLVOk = true;

                        if ((impVal.length + 1) > maxLength) {

                            //console.log('(impVal.length + 1) >= maxLength :' + (impVal.length + 1) >= maxLength);
                            if (frVOk) e.preventDefault();
                            if (frLVOk) e.preventDefault();
                        }
                        if (frVOk && frLVOk) {
                            e.preventDefault();
                        }
                    }
                    else {
                        var impLength = (impVal.length + 1);
                        if (firstLength < impLength && e.keyCode != 188 && e.keyCode != 190 && !e.keyCode == 110) e.preventDefault();
                    }
                }
            }
            var _id=$(sndr).attr('id');
            replaceCharMyMsk(_id,e.keyCode);
        }

        function replaceCharMyMsk(id,kKod){
            setTimeout(function(){
                if(kKod==190){
                    var val=$('#'+id).val();
                    $('#'+id).val($('#'+id).val().replace('.', ","));
                }
            },150);
        }
