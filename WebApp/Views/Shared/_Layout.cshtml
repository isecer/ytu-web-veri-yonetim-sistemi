                    </a>
                    <div class="profile">
                        <div class="profile-image">
                            <div class="tile tile-primary" style="margin: 0px; padding: 0px; background-color:transparent;">
                                <div class="mn profile-image">
                                    <img src="~/Content/assets/images/ytu_logo_tr.png" />
                                    <script>
                                        setTimeout(function () {
                                            $('.mn.profile-image').find("img").attr("src", "@lImage");
                                        }, 200)
                                    </script>
                                </div>
