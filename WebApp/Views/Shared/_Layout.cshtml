@using WebApp.Models
@using WebApp.Utilities.Extensions
@using WebApp.Utilities.Helpers
@using WebApp.Utilities.MenuAndRoles
@using WebApp.Utilities.MessageBox
@{
    var urlInfo = Request.Url.ToUrlInfo();

    var fixedHeader = UserIdentity.Current.Informations.Any(p => p.Key == "FixedHeader") && UserIdentity.Current.Informations["FixedHeader"].ToBooleanObj().Value;
    var fixedSidebar = UserIdentity.Current.Informations.Any(p => p.Key == "FixedSidebar") && UserIdentity.Current.Informations["FixedSidebar"].ToBooleanObj().Value;
    var scrollSidebar = UserIdentity.Current.Informations.Any(p => p.Key == "ScrollSidebar") && UserIdentity.Current.Informations["ScrollSidebar"].ToBooleanObj().Value;
    var rightSidebar = UserIdentity.Current.Informations.Any(p => p.Key == "RightSidebar") && UserIdentity.Current.Informations["RightSidebar"].ToBooleanObj().Value;
    var customNavigation = UserIdentity.Current.Informations.All(p => p.Key != "CustomNavigation") || UserIdentity.Current.Informations["CustomNavigation"].ToBooleanObj().Value;
    var toggledNavigation = UserIdentity.Current.Informations.Any(p => p.Key == "ToggledNavigation") && UserIdentity.Current.Informations["ToggledNavigation"].ToBooleanObj().Value;
    var boxedOrFullWidth = UserIdentity.Current.Informations.All(p => p.Key != "BoxedOrFullWidth") || UserIdentity.Current.Informations["BoxedOrFullWidth"].ToBooleanObj().Value;
    var themeName = UserIdentity.Current.Informations.Any(p => p.Key == "ThemeName") ? UserIdentity.Current.Informations["ThemeName"].ToString() : "/Content/css/theme-forest.css";
    var backgroundImage = UserIdentity.Current.Informations.Any(p => p.Key == "BackgroundImage") ? UserIdentity.Current.Informations["BackgroundImage"].ToString() : "wall_2";
    if (boxedOrFullWidth)
    {
        fixedHeader = false;
        fixedSidebar = false;
    }
    var lImage = "/Content/assets/images/ytu_logo_tr.gif?nID=" + Guid.NewGuid();
}

