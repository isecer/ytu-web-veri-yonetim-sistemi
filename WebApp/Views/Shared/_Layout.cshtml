                                       +'<a href="javascript:void(0);" data-wall="wall_7"><img src="/Content/img/backgrounds/wall_7.jpg"/></a>'
                                       +'<a href="javascript:void(0);" data-wall="wall_8"><img src="/Content/img/backgrounds/wall_8.jpg"/></a>'
                                       +'<a href="javascript:void(0);" data-wall="wall_9"><img src="/Content/img/backgrounds/wall_9.jpg"/></a>'
                                       +'<a href="javascript:void(0);" data-wall="wall_10"><img src="/Content/img/backgrounds/wall_10.jpg"/></a>'
                                   +'</div>'
                               +'</div>'
                           +'</div>';

            var settings_block = document.createElement('div');
            settings_block.className = "theme-settings";
            settings_block.innerHTML = site_settings;
            document.body.appendChild(settings_block);
            var st_head_fixed=@Convert.ToInt32(fixedHeader);
            var st_sb_fixed=@Convert.ToInt32(fixedSidebar);
            var st_sb_scroll= @Convert.ToInt32(scrollSidebar);
            var st_sb_right= @Convert.ToInt32(rightSidebar);
            var st_sb_custom= @Convert.ToInt32(customNavigation);
            var st_sb_toggled= @Convert.ToInt32(toggledNavigation);
            var st_layout_boxed= @Convert.ToInt32(boxedOrFullWidth);
            var _BackgroundImage= '@backgroundImage';
            var _ThemeName='@themeName';

            set_settings_checkbox("st_layout_boxed",st_layout_boxed);
            set_settings_checkbox("st_sb_scroll",st_sb_scroll);
            set_settings_checkbox("st_sb_right",st_sb_right);
            set_settings_checkbox("st_sb_custom",st_sb_custom);
            set_settings_checkbox("st_sb_toggled",st_sb_toggled);
            if (st_layout_boxed == 1) {
                set_settings_checkbox("st_head_fixed",-1);
                $('input[name=st_head_fixed]').parents('label').addClass("disabled");
                set_settings_checkbox("st_sb_fixed",-1);
                $('input[name=st_sb_fixed]').parents('label').addClass("disabled");

                $('#ts-wallpapers .ts-themes').find('a').each(function(inx,ax){
                    var $_a=$(ax);
                    var atrVal=$_a.attr('data-wall');
                    if(atrVal==_BackgroundImage){
                        $_a.addClass("active");
                    }
                    else {
                        $_a.removeClass("active");
                    }
                });
                $("#ts-wallpapers").show();
            }
            else {
                set_settings_checkbox("st_head_fixed",st_head_fixed);
                set_settings_checkbox("st_sb_fixed",st_sb_fixed);
                $("#ts-wallpapers").hide();
            }
            $('#ts-themesX').find('a').each(function(inx,ax){
                var $_a=$(ax);
                var atrVal=$_a.attr('data-theme');
                if(atrVal==_ThemeName){
                    $_a.addClass("active");
                }
                else {
                    $_a.removeClass("active");
                }
            });
            function setUserTheme(columnName,value) {
                $.ajax({
                    url: '@Url.Action("SetThemeSetting", "Ajax")',
                    data: { columnName: columnName, value: value },
                    success: function (result) {

                    },
                    error: function (err) {
                    }
                });
            }



        </script>
    }
