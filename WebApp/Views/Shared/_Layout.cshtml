                                    <li style="cursor: pointer;">


                                        <a href="javasscript:void(0); " style="text-align: center; font-size: 17pt; color: #ffd559; padding: 0px;">
                                            VYS
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div class="profile-data">
                            <div class="profile-data-title" style="font-size:11pt;">
                                Veri Yönetim Sistemi
                            </div>

                        </div>
