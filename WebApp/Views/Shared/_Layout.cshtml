            <!-- START X-NAVIGATION VERTICAL -->
            <ul class="x-navigation x-navigation-horizontal x-navigation-panel">
                <!-- TOGGLE NAVIGATION -->

                @if (UserIdentity.Current.IsAuthenticated)
                {   
                    var prevUserKey = UserIdentity.Current.Informations.FirstOrDefault(p => p.Key == "PrevUserKey");

                    <!-- PROFILE -->
                    <li class="dropdown user pull-right" style="padding-top: 0px; padding-bottom: 0px;">
                        <a style="padding-bottom: 0px;" href="javascript:void(0)" class="dropdown-toggle" data-close-others="true">

                            <img id="userMainImg" style="margin-top: -12px; width: 45px; height: 45px;" src="@UserIdentity.Current.ImagePath">
                            <span class="xn-text" style="margin-top: 10px;">@UserIdentity.Current.AdSoyad</span>
                            <i class="fa fa-angle-down"></i>
                        </a>
                        <ul class="xn-drop-left animated zoomIn" style="z-index:997;">
                            <li><a href="javascript:void(0)" onclick="detayGor(@UserIdentity.Current.Id)"><i class="fa fa-user"></i>Detay Göster</a></li>
                            @if (prevUserKey.Key != null)
                            {
                                <li><a href="@Url.Action("SetLogin","Kullanicilar",new { UserIdentity.Current.UserKey,key=prevUserKey.Value })"><i class="fa fa-user"></i> Önceki Hesaba Geç</a></li>
                            } 
                            @if (UserIdentity.Current.IsActiveDirectoryUser == false)
                            {
                                <li><a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Şifre Değiştir', '@(Url.Action("ParolaSifirla", "Account", new { KullaniciID = UserIdentity.Current.Id }))', 430, '@ModalSizeClass.Basic')"><span class="fa fa-lock"></span>Şifreyi değiştir</a></li>
                            }
                            <li><a href="javascript:void(0);" onclick="yetkiYenile();"><span class="fa fa-refresh"></span>Yetklilerimi Yenile</a></li>
                            <li><a href="javascript:void(0);" class="mb-control" data-box="#mb-signout"><span class="fa fa-sign-out"></span>Çıkış Yap</a></li>
                        </ul>
                        <div class="message-box animated fadeIn" data-sound="alert" id="mb-signout">
                            <div class="mb-container">
                                <div class="mb-middle">
                                    <div class="mb-title"><span class="fa fa-sign-out"></span><strong>Çıkış Yap</strong> ?</div>
                                    <div class="mb-content">
                                        <p>Çıkış yapmak istediğinizden emin misiniz?</p>
                                    </div>
                                    <div class="mb-footer">
                                        <div class="pull-right">
                                            <a href="javascript:void(0)" class="btn btn-success btn-lg" onclick="SignOut()">Evet</a>
                                            <button class="btn btn-default btn-lg mb-control-close">Hayır</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <script type="text/javascript">
                        function yetkiYenile() {
                            $.ajax({
                                url:'@Url.Action("YetkiYenile", "Ajax")',
                                data: {'ReturnUrl':'@urlInfo.AbsolutePath'},
                                success: function (result) {
                                    if (result.IsSuccess) {
                                        if (result.ReturnUrl != null && result.ReturnUrl != "")
                                            window.location.href = result.ReturnUrl;
                                    }
                                },
                                error: function (err) {
                                    alert(err.responseText);
                                }
                            });
                        }
                        function SignOut() {
                            $.ajax({
                                url:'@Url.Action("SignOut", "Ajax")',
                                data: {},
                                success: function (result) {
                                    if (result.IsSuccess) {
                                        if (result.ReturnUrl != null && result.ReturnUrl != "")
                                            window.location.href = result.ReturnUrl;
                                    }
                                },
                                error: function (err) {
                                    alert(err.responseText);
                                }
                            });
                        }
                        </script>

                    </li>
                    <!--END PROFILE -->
                }
                @if (UserIdentity.Current.IsAuthenticated && RoleNames.Mesajlar.InRole())
                {
                    var MsjModel = MesajlarBus.GetCevaplanmamisMesajCount();
                    <li class="xn-icon-button pull-right" id="_msgCountLi">
                        <a href="javascript:void(0);"><span class="fa fa fa-envelope fa-lg"></span></a>
                        <div id="_msjCount" class="informer informer-@(MsjModel.Value>0?"warning":"success")">@MsjModel.Value</div>
                        <div id="_msgContent" class="panel panel-primary animated zoomIn xn-drop-left xn-panel-dragging ui-draggable">
                            <div class="panel-heading ui-draggable-handle padding-0">
                                <h3 class="panel-title"><span class="fa fa fa-envelope fa-lg"></span> Gelen Mesajlar</h3>
                                <div class="pull-right">
                                    <span id="_msjCount2" class="label label-@(MsjModel.Value>0?"warning":"success")">@MsjModel.Value Açık Mesaj</span>
                                </div>
                            </div>
                            <div class="panel-body list-group list-group-contacts _mCS_2" style="max-height: 200px;">
                                <div id="mCSB_2" class="scrolkikkoxMsj" tabindex="0">
                                    <div id="mCSB_2_container" style="position: relative; top: 0px; left: 0px;" dir="ltr">
                                        @Html.Raw(MsjModel.Caption)
                                    </div>
                                </div>
                            </div>
                            <div class="panel-footer text-center padding-0">
                                <a href="@Url.Action("Index","Mesajlar")">Tüm Mesajları Gör</a>
                            </div>
                        </div>
                        <script>
                            $(function () {
                                if (@MsjModel.Value>0) {
                                    MessageCntPulsate();
                                    $('.scrolkikkoxMsj').slimScroll({
                                        color: 'red',
                                        height: '200px'
                                    });
                                }
                            })
                            function MessageCntPulsate() {
                                $('#_msgCountLi').pulsate({ color: "#fdbe41", reach: 60, repeat: 14, speed: 300, glow: true });
                                $('#_msgContent').pulsate({ color: "#fdbe41", reach: 60, repeat: 14, speed: 300, glow: true });
                            }
                            var tmrMsg = null;
                            $(function () {
                                tmrMsgFnc(1, 30000);
                            });

                            function tmrMsgFnc(eventType, time) {
                                if (eventType == 0) clearInterval(tmrMsg);
                                else if (eventType == 1) {
                                    tmrMsg = setInterval(function () { GetAcikMsjCount() }, time);
                                }
                                else if (eventType == 2) {
                                    clearInterval(tmrLogn);
                                    tmrMsg = setInterval(function () { GetAcikMsjCount() }, time);
                                }
                            }
                            function GetAcikMsjCount() {
                                var panel = $('#_msgContent');
                                _pRefresh(panel, false);
                                $.ajax({
                                    url: '@Url.Action("GetAcikMsjCount", "Mesajlar")',
                                    data: {},
                                    success: function (result) {

                                        var oldCount = parseInt($('#_msjCount').text());
                                        $('#_msjCount').removeClass('informer-warning').removeClass('informer-success');
                                        $('#_msjCount2').removeClass('label-warning').removeClass('label-success');
                                        if (result.mCount > 0) {
                                            $('#_msjCount').addClass('informer-warning');
                                            $('#_msjCount2').addClass('label-warning');
                                        }
                                        else {
                                            $('#_msjCount').addClass('informer-success');
                                            $('#_msjCount2').addClass('label-success');
                                        }
                                        $('#_msjCount').html(result.mCount);
                                        $('#_msjCount2').html(result.mCount + " Açık Mesaj");
                                        $('#mCSB_2_container').html(result.HtmlContent);
                                        if (result.mCount > oldCount) {
                                            $('#_msgCountLi').addClass('active');
                                            MessageCntPulsate();
                                        }

                                        _pRefresh(panel, true);
                                        trmlognFnc(2, 30000);
                                    },
                                    error: function (err) {
                                        _pRefresh(panel, true);
                                        trmlognFnc(0);
                                    }
                                });

                            }
                        </script>
                    </li>
                }
                @if (UserIdentity.Current.IsAuthenticated && RoleNames.KullanicilarOnlineList.InRole())
                {
                    <li class="xn-icon-button pull-right" style="cursor:pointer;" onclick="getOnlineUsers()">
                        <a href="javascript:void(0)" onclick="getOnlineUsers()"><span class="fa fa-group"></span></a>
                        <div id="userCnt" class="informer informer-success">@OnlineUsers.OnlineUserCount</div>
                        <div id="oUserList" style="min-height: 100px;z-index:999;" class="panel panel-primary animated zoomIn xn-drop-left xn-panel-dragging"></div>

                        <script type="text/javascript">
                            var tmrLogn = null;
                            $(function () {
                                trmlognFnc(1, 30000);
                            });

                            function trmlognFnc(eventType, time) {
                                if (eventType == 0) clearInterval(tmrLogn);
                                else if (eventType == 1) {
                                    tmrLogn = setInterval(function () { OnlineUserKontrol() }, time);
                                }
                                else if (eventType == 2) {
                                    clearInterval(tmrLogn);
                                    tmrLogn = setInterval(function () { OnlineUserKontrol() }, time);
                                }
                            }
                            function OnlineUserKontrol() {
                                $.ajax({
                                    url: '@Url.Action("OnlineUserCnt", "Account")',
                                    data: {},
                                    success: function (result) {
                                        $('#userCnt').html(result);
                                        trmlognFnc(2, 30000);
                                    },
                                    error: function (err) {
                                        trmlognFnc(0);
                                    }
                                });

                            }
                            function getOnlineUsers() {

                                var _panel = $('#oUserList');
                                _pRefresh(_panel, false);
                                $.ajax({
                                    url: '@Url.Action("getOnlineUserList", "Account")',
                                    data: {},
                                    success: function (result) {
                                        $('#oUserList').html(result);
                                        _pRefresh(_panel, true);
                                    },
                                    error: function (err) {
                                        _pRefresh(_panel, true);
                                    }
                                });

                            }

                        </script>
                    </li>
                }


                <!-- END LANG BAR -->
                <!-- LOGIN BLOCk -->
                @if (!UserIdentity.Current.IsAuthenticated)
                {
                    <li class="pull-right" id="loginPanel">
                        <a href="javascript:void(0);">Giriş Yap <span class="fa fa-lock fa-lg"></span></a>
                        <div class="informer informer-danger"><span class="fa fa-info"></span></div>
                        <div class="pnlLgn panel panel-primary animated zoomIn xn-drop-left loginPulsate">
                            <div class="panel-heading padding-0">
                                <h3 class="panel-title"><strong>Giriş Yap</strong></h3>
                            </div>
                            <div class="panel-body">

                                <div class="login-container login-v2 login-inside">
                                    <input type="text" id="RetUrl" class="hide" value="@urlInfo.AbsolutePath" />
                                    <div class="login-box animated fadeInDown">
                                        <div class="login-body">

                                            <div class="form-horizontal">

                                                <div class="form-group">
                                                    <div class="input-group">
                                                        <div class="input-group-addon">
                                                            <span class="fa fa-user"></span>
                                                        </div>
                                                        <input type="text" id="UserName" class="form-control" placeholder="Kullanıcı Adı" value="" />
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <div class="input-group">
                                                        <div class="input-group-addon">
                                                            <span class="fa fa-lock"></span>
                                                        </div>
                                                        <input type="password" id="Password" class="form-control" placeholder="Şifre" value="" />
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <div class="input-group">
                                                        @{ var reqCode = Guid.NewGuid().ToString().Replace("-", "");
                                                            <input type="hidden" name="captchaRequestCode" value="@reqCode" id="captchaRequestCode" />
                                                            <div class="input-group-addon">
                                                                <span class="fa fa-lock"></span>
                                                            </div>
                                                            <img style="max-height:80px;" class="form-control" id="captchaImg" src="@Url.Action("Generatecaptcha", "Account", new { captchaRequestCode = @reqCode })" alt="??" />
                                                            <input id="CaptchaText" class="form-control placeholder-no-fix" type="text" autocomplete="off" placeholder="Güvenlik Kodu" name="CaptchaText" />
                                                        }
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <div class="col-md-6">
                                                        <a href="javascript:void(0);" onclick="$('.pnlsndPwd').removeClass('hide'); $('.pnlLgn').addClass('hide');">Şifrenizi mi unuttunuz?</a>
                                                    </div>
                                                    @*<div class="col-md-6">
                                                            <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Bir hesap oluşturun', '@(Url.Action("HesapKayit", "Account"))', 'auto', '@ModalSizeClass.Large')">Bir hesap oluşturun</a>
                                                        </div>*@
                                                </div>
                                                <div class="form-group">
                                                    <div class="col-md-12">
                                                        <button class="btn btn-primary btn-lg btn-block" onclick="loginControl()">Giriş Yap</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>
                        </div>
                        <div class="pnlsndPwd panel panel-primary animated zoomIn xn-drop-left loginPulsate hide">
                            <div class="registration-container">
                                <div class="registration-box animated fadeInDown" style="padding-top: 2px;">
