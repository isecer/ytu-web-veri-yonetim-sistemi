            <ul class="x-navigation  @(customNavigation ? "x-navigation-custom" : "")">
                <li class="xn-logo">
                    <a href="javascript:void(0);" style="background-color:transparent;">YTU</a>
                    <a href="javascript:void(0);" class="x-navigation-control"></a>
                </li>

                <li class="xn-profile">
