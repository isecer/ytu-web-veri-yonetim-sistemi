    <meta content="" name="description" />
    <meta content="" name="author" />
    <meta name="MobileOptimized" content="320">
    <!-- BEGIN GLOBAL MANDATORY STYLES -->
    <!-- CSS INCLUDE -->
    <link rel="stylesheet" type="text/css" id="theme" href="~/Content/css/theme-default.css" />
    <link href="~/Content/assets/plugins/select2/select2.css" rel="stylesheet" />
    <link href="~/Content/assets/plugins/bootstrap-switch/static/stylesheets/bootstrap-switch.css" rel="stylesheet" />
    <!-- EOF CSS INCLUDE -->
    <!-- START PLUGINS -->
    <script type="text/javascript">
        var root = '@root';
    </script>

    <script type="text/javascript" src="~/Content/js/plugins/jquery/jquery.min.js"></script>
    <script type="text/javascript" src="~/Content/js/plugins/jquery/jquery-ui.min.js"></script>
    <script src="~/Content/assets/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
    <script src="~/Scripts/jquery.mask.js"></script>
    <script type="text/javascript" src="~/Content/js/plugins/bootstrap/bootstrap.min.js"></script>
    <script src="~/Content/js/plugins/bootstrap/bootstrap-select.js"></script>

    <link href="~/Content/assets/plugins/myDatetime/jquery.datetimepicker.min.css" rel="stylesheet" /> 
    @*<script src="~/Content/assets/plugins/myDatetime/jquery.datetimepicker.js"></script>*@
    <script src="~/Content/assets/plugins/myDatetime/jquery.datetimepicker.full.js"></script>
    @* <script src="~/Content/js/plugins/bootstrap/bootstrap-timepicker.min.js"></script>*@

</head>
<body style="padding: 0px;">
    <div class="col-md-12" style="padding: 4px; margin: 0px;">
        @RenderBody()
        @{
            if (UserIdentity.Current.IsAuthenticated)
            {
                var msgs = MessageBox.GetShows();

                if (msgs != null && msgs.Length > 0)
                {
                    <div id="msgs" style="display: none;">
                        @foreach (var msg in msgs)
                        {
                            var cls = msg.MsgType == MessageBox.MessageType.Success ?
                                "success" : (msg.MsgType == MessageBox.MessageType.Warning ? "warning" : (msg.MsgType == MessageBox.MessageType.Error ? "danger" : "info"));
                            <div class="panel panel-@cls" style="margin-bottom:3px;">

                                <div class="panel-body panel-body-pricing">
                                    @if (!msg.Title.IsNullOrWhiteSpace())
                                    {
                                        <h3 class="text-@cls">@Html.Raw(msg.Title)</h3>
                                    }
                                    @foreach (var itemmsg in msg.Message)
                                    {
                                        <p style="margin:0px;padding:0px;">
                                            <span class="fa fa-caret-right"></span> @Html.Raw(itemmsg)
                                        </p>
                                    }
                                </div>

                            </div>
                        }
                    </div>
                }
                else
                {
                    var mmmsgs = new MmMessage();
                    if (Session["ShwMesaj"] != null)
                    {
                        mmmsgs = (MmMessage)Session["ShwMesaj"];
                        Session["ShwMesaj"] = null;
                    }
                    if (mmmsgs.Messages.Count > 0)
                    {
                        <div id="msgs" style="display: none;">
                            @{
                                var cls = mmmsgs.MessageType == Msgtype.Success ? "success" : (mmmsgs.MessageType == Msgtype.Warning ? "warning" : (mmmsgs.MessageType == Msgtype.Error ? "danger" : "info"));
                                <div class="panel-body panel-body-pricing">
                                    @if (!mmmsgs.Title.IsNullOrWhiteSpace())
                                    {
                                        <h3 class="text-@cls">@Html.Raw(mmmsgs.Title)</h3>
                                    }
                                    @foreach (var itemmsg in mmmsgs.Messages)
                                    {
                                        <p style="margin:0px;padding:0px;">
                                            <span class="fa fa-caret-right"></span> @Html.Raw(itemmsg)
                                        </p>
                                    }
                                </div>
                            }
                        </div>


                                        }
                                    }
                                }
                                else
                                {
                                    var mmmsgs = new MmMessage();
                                    if (Session["ShwMesaj"] != null)
                                    {
                                        mmmsgs = (MmMessage)Session["ShwMesaj"];
                                        Session["ShwMesaj"] = null;
                                    }
                                    if (mmmsgs.Messages.Count > 0)
                                    {
                                        <div id="msgs" style="display: none;">
                                            @{
                                                var cls = mmmsgs.MessageType == Msgtype.Success ? "success" : (mmmsgs.MessageType == Msgtype.Warning ? "warning" : (mmmsgs.MessageType == Msgtype.Error ? "danger" : "info"));
                                                <div class="panel-body panel-body-pricing">
                                                    @if (!mmmsgs.Title.IsNullOrWhiteSpace())
                                                    {
                                                        <h3 class="text-@cls">@Html.Raw(mmmsgs.Title)</h3>
                                                    }
                                                    @foreach (var itemmsg in mmmsgs.Messages)
                                                    {
                                                        <p style="margin:0px;padding:0px;">
                                                            <span class="fa fa-caret-right"></span> @Html.Raw(itemmsg)
                                                        </p>
                                                    }
                                                </div>
                                            }
                                        </div>


                                                    }



                                                }
        }
    </div> 
</body>
<script type="text/javascript" src="~/Content/js/plugins/bootstrap/bootstrap.min.js"></script>
<script type='text/javascript' src="~/Content/js/plugins/icheck/icheck.min.js"></script>
