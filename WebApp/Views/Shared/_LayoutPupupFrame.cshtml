<script type="text/javascript" src="~/Content/assets/plugins/select2/select2.js"></script>
<script type="text/javascript" src="~/Content/assets/plugins/select2/select2_locale_tr.js"></script>

<script>
    $('.scrolkikko').slimScroll({
        color: '#9bbb67'
    });
    $('.date-picker').datetimepicker({
        lang: 'tr',
        startDate: '',
        timepicker: false,
        format: 'd-m-Y'
    });
    function blockUI(el, centerY) {
        var el = jQuery(el);
        if (el.height() <= 400) {
            centerY = true;
        }
        el.block({
            message: '<img src="' + root + 'Content/img/loaders/ajax-loading.gif" align="">',
            centerY: centerY != undefined ? centerY : true,
            css: {
                top: '10%',
                border: 'none',
                padding: '2px',
                backgroundColor: 'none'
            },
            overlayCSS: {
                backgroundColor: '#000',
                opacity: 0.05,
                cursor: 'wait'
            }
        });
    }

    // wrapper function to  un-block element(finish loading)
    function unblockUI(el) {
        jQuery(el).unblock({
            onUnblock: function () {
                jQuery(el).removeAttr("style");
            }
        });
    }
    function showMmMessage(msgs, btnName) {
        bootbox.dialog({
            message: $.parseHTML(msgs),
            buttons: {
                danger: {
                    label: btnName,
                    className: "btn-success",
                    callback: function () {
                    }
                }
            }
        });
    }
    function _pRefresh(panel, IsRemove) {
        if (IsRemove) {
            panel.find(".panel-refresh-layer").remove();
            panel.removeClass("panel-refreshing");
        }
        else {
            panel_refresh(panel);
        }


    }
</script>

<script type="text/javascript">
    setTimeout(function () {

        if ($('#msgs').length > 0) {
            bootbox.dialog({
                message: $('#msgs').html(),
                buttons: {
                    danger: {
                        label: "Tamam",
                        className: "btn-success",
                        callback: function () {
                        }
                    }
                }
            });
        }
        $('.tooltips').tooltip();
    }, 150);
</script>