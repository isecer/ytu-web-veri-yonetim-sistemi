@using WebApp.Models
@model List<FrMaddeler>
@{

    Layout = null;
}
<div class="panel-body" style="padding: 0px;">
    <div class="panel panel-primary">
        <div class="panel-body padding-0">
            <table class="table table-hover" style="width:100%;table-layout:fixed;margin-bottom:0px;">
                <thead>
                    <tr>
                        <th width="80">M Kod</th>
                        <th>Madde Adı</th>
                        <th width="110" title="Aktif Yıl Planlanan Değer Bilgisi" style="text-align:right;">Aktif Yıl Pln. Değer</th>
                        <th width="110" title="Gelecek Yıl Planlanan Değer Bilgisi" style="text-align:right;">G. Yıl Pln. Değer</th>
                        <th width="90" title="Madde Veri Giriş Durumu" style="text-align:right;">V.G Durum</th>
                    </tr>
                </thead>
                @foreach (var itemObt in Model)
                {

                <tr class="tr">
                    <td>@itemObt.MaddeKod</td>
                    <td>
                        @itemObt.MaddeAdi
                    </td>
                    <td style="font-size:11pt; font-weight:bold;text-align:right;">
                        @if (itemObt.IsPlanlananDegerOlacak)
                        {

                            <span style="color:@(itemObt.PlanlananDeger.HasValue?"#95b75d":"#3fbae4")">@(itemObt.PlanlananDeger.HasValue ? $"{itemObt.PlanlananDeger.Value:0.###}" : "Girilmedi")</span>
                        }
                        else
                        {
                            <span style="color:gray;">Yok</span>
                        }

                    </td>
                    <td style="font-size:11pt; font-weight:bold;text-align:right;">
                        @if (itemObt.IsPlanlananDegerOlacakGelecekYil)
                        {

                            <span style="color:@(itemObt.PlanlananDegerGelecekYil.HasValue?"#95b75d":"#3fbae4")">@(itemObt.PlanlananDegerGelecekYil.HasValue ? $"{itemObt.PlanlananDegerGelecekYil.Value:0.###}" : "Girilmedi")</span>
                        }
                        else
                        {
                            <span style="color:gray;">Yok</span>
                        }

                    </td>
                    <td style="font-size:13pt; font-weight:bold;text-align:right;">
                        <span style="color:@(itemObt.GirilenVeriSayisi== itemObt.GirilecekVeriSayisi?"#95b75d":"#3fbae4")">@itemObt.GirilenVeriSayisi / @itemObt.GirilecekVeriSayisi</span>
                    </td>
                </tr>

                }
            </table>
        </div>
    </div>
</div>

