@using WebApp.Utilities.Extensions
@model WebApp.Utilities.Dtos.FrVgMaddeler
@{
    var colorOnay = Model.VeriGirisiOnaylandi ? "green" : "maroon";
    var colorVeri = Model.GirilenVeriSayisi == Model.GirilecekVeriSayisi ? "green" : "maroon";
    var colorVeriOnay = Model.OnaylananVeriSayisi == Model.GirilecekVeriSayisi ? "green" : "maroon";
    var styleWidthVg = 40;
    var styleWidthVo = 70;
    var isCokluVeri = Model.GirilecekVeriSayisi > 1;
}
<table style="width:100%;color:@colorOnay">

    @if (isCokluVeri)
    {
        var hesaplamaOnAd = Model.HesaplamaFormulu.IsNullOrWhiteSpace() ? (Model.MaddeYilSonuDegerHesaplamaTipID == 2 ? Model.GirilecekVeriSayisi + " Dönemin Kümülatif Toplamı" : Model.MaddeYilSonuDegerHesaplamaTipID == 1 ? Model.GirilecekVeriSayisi + " Dönemin Ortalaması" : "Son Dönem Verisi") : "Formül: " + Model.HesaplamaFormulu.ToUpper();
        <tr> 
            <td colspan="4" style="font-size: 7pt;" title="Hesaplama Şekli">@hesaplamaOnAd</td>
        </tr>
    }

    <tr>
        <td width="@styleWidthVg" style="color:@colorVeri;font-size: 7pt; padding-left: 3px; border-bottom: 1px solid;" title="Veri giriş durumu">V.Girişi</td>
        <td width="@styleWidthVg" style="color:@colorVeri;font-size: 9pt; font-weight: bold;border-bottom:1px solid;border-right:1px solid;padding-right:2px;" title="Veri Giriş Durumu">@Model.GirilenVeriSayisi/@Model.GirilecekVeriSayisi</td>

        <td width="@styleWidthVo" style="font-size: 7pt; padding-left: 3px; border-bottom: 1px solid;" title="Madde Yıl Sonu Planlanan Değer">Planlanan =></td>
        <td style="font-size: 9pt; font-weight: bold;border-bottom:1px solid;" title="Madde Yıl Sonu Planlanan Değer">@(Model.IsPlanlananDegerOlacak?Model.PlanlananDeger.ToNumberFormat(Model.HesaplananSonucDegeri):"Yok")</td>

    </tr>


    <tr>
        <td width="@styleWidthVg" style="color: @colorVeriOnay;font-size: 7pt; padding-left: 3px;" title="Veri onay durumu">V.Onayı</td>
        <td width="@styleWidthVg" style="color: @colorVeriOnay;font-size: 9pt; font-weight: bold;border-right:1px solid;padding-right:2px;" title="Veri onay durumu">@Model.OnaylananVeriSayisi/@Model.GirilecekVeriSayisi</td>

        <td width="@styleWidthVo" style="font-size: 7pt; padding-left: 3px;" title="Madde Yıl Sonu Hesaplanan Değer Sonucu">Sonuç =></td>
        <td style="font-size: 9pt;font-weight:bold;" title="Madde Yıl Sonu Hesaplanan Değer Sonucu">
            @(Model.VeriGirisiOnaylandi? Model.HesaplananSonucDegeri.ToNumberFormat(Model.PlanlananDeger) :"------")
        </td>
    </tr>
</table>

