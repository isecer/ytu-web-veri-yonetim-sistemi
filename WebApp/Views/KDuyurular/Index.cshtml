@using WebApp.Models
@using WebApp.Utilities.Extensions
@model FmDuyurular
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-bullhorn"></i> Duyurular</h3>
                    <ul class="panel-controls">
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75" style="border-right: 0px"></th>
                                @* <th width="150" class="sirala sorting" field="EnstituAd">Enstitu</th>*@
                                <th width="110" class="sirala sorting" field="Tarih" style="width: 120px;">Tarih</th>
                                <th class="sirala sorting" field="Baslik">Başlık</th>
                                <th width="40" class="sirala sorting" field="EkSayisi"><i class="fa fa-download"></i></th>
                            </tr>

                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                @*<th>
                                        @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                    </th>*@
                                <th>
                                    @*<input type="text" name="Tarih" value="@(Model.Tarih.HasValue?Model.Tarih.Value.ToString("dd-MM-yyyy"):"")" class="form-control date-picker" />*@
                                </th>
                                <th>
                                    <input type="text" name="Baslik" value="@Model.Baslik" class="form-control" />
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                var rowIndex = Model.StartRowIndex;
                                foreach (var item in Model.Data)
                                {
                                    rowIndex++; 
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width:30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.DuyuruID" onclick="ShowDetail(@item.DuyuruID)">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span> </a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td> 
                                        <td>
                                            @item.Tarih.ToFormatDateAndTime()
                                        </td>
                                        <td>
                                            @(item.Baslik.Length > 70 ? item.Baslik.Substring(0, 69) + "..." : item.Baslik)
                                        </td>
                                        <td>
                                            <img src="~/Images/Attachment.png" style="height: 16px;" />@item.EkSayisi
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.DuyuruID hide">
                                        <td id="cls-@item.DuyuruID" colspan="5">
                                            <div class="panel panel-primary form-horizontal" style="margin-bottom:0px;">
                                                <div class="panel-body form-group-separated">
                                                    <div class="form-group">
                                                        <div class="col-md-12 col-xs-12  padding-top-0 padding-bottom-0 " style="text-align: left;">
                                                            <div class="panel panel-default" style="margin:0px;padding:0px;">
                                                                <div class="panel-body" style="padding-right:0px;">
                                                                    <div class="scrolkikko" style="max-height: 400px; width:100%; overflow:hidden;">
                                                                        @Html.Raw(item.AciklamaHtml)
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="form-group">
                                                            <label class="col-md-2 col-xs-2 control-label padding-top-0 padding-bottom-0">Ekler <img src="~/Images/Attachment.png" style="height: 16px;" /></label>
                                                            <div class="col-md-10  col-xs-10 padding-top-0 padding-bottom-0 " style="text-align: left;">
                                                                <div class="scrolkikko" style="max-height: 100px; width:100%; overflow:hidden;">
                                                                    <table style="width: 100%; table-layout: fixed;">
                                                                        @if (item.EkSayisi > 0)
                                                                        {
                                                                            foreach (var item2 in item.DuyuruEkleris.Select((s, inx) => new { inx, s }))
                                                                            {
                                                                                <tr>
                                                                                    <td style="width: 25px;">@(item2.inx + 1))</td>
                                                                                    <td class="name"><a href="@item2.s.DosyaYolu" target="_blank"><span class="fa fa-download" style="color: green;"></span>&nbsp;@item2.s.DosyaEkAdi</a></td>
                                                                                </tr>
                                                                            }
                                                                        }
                                                                        else
                                                                        {
                                                                            <tr>
                                                                                <td colspan="2">Ek Yok</td>
                                                                            </tr>
                                                                        }

                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" style="text-align: center">
                                        Duyuru Yok
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Html.Raw(Model.ToPagerString().ToString())
                </div>
            </div>
        </div>
    }
</div>


<script type="text/javascript">

    function ShowDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).hasClass("hide"));
        toggleByClass(sndr, cls, unTogled);

    }
</script>