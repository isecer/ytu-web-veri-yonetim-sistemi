@using Database
@using WebApp.Business
@using WebApp.Utilities.Extensions
@using WebApp.Utilities.Helpers
@using WebApp.Utilities.MessageBox
@model GTBirimler
@{
    var mmMessage = ViewBag.MmMessage as MmMessage;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var secilenlerHn = (List<int>)ViewBag.SecilenlerHN;
    var bhnData = BirimlerBus.GetGtBirimHesapNumaralari(Model.GTBirimID, secilenlerHn);
    bhnData.InputName = "GTHesapNoID";
    bhnData.PanelTitle = "İlgili Hesap Numaralarını Seçiniz";
    var secilenlerHk = (List<int>)ViewBag.SecilenlerHK;
    var bhkData = BirimlerBus.GetGtBirimHesapKodlari(Model.GTBirimID, secilenlerHk);
    bhkData.InputName = "GTHesapKodID";
    bhkData.PanelTitle = "İlgili Hesap Kodlarını Seçiniz";

}
<div class="row">
    <form method="post" class="form-horizontal" role="form">
        <input type="text" style="display:none;" id="GTBirimID" name="GTBirimID" value="@Model.GTBirimID" />
        <div class="col-md-12 col-md-12 col-md-12">
            <div class="panel panel-default" id="bPanel">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i> @(Model.GTBirimID <= 0 ? "Yeni Birim Tanımlama" : "Varolan Birim Güncelleme İşlemi")</h3>
                    <ul class="panel-controls">
                        <li><a href="@Url.Action("Kayit","GTBirimler",new {id= Model.GTBirimID })" class=""><span class="fa fa-refresh panel-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <div class="panel panel-default form-horizontal">
                        <div class="panel-body form-group-separated">

                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Birim Kodu</label>
                                <div class="col-md-10 col-xs-10">
                                    <input type="text" name="BirimKod" id="BirimKod" value="@Model.BirimKod" maxlength="11" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Birim Adı</label>
                                <div class="col-md-10 col-xs-10">
                                    <input type="text" name="BirimAdi" id="BirimAdi" value="@Model.BirimAdi" class="form-control" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Hesap Numaraları</label>
                                <div class="col-md-10 col-xs-10">
                                    @bhnData.ToRenderPartialViewHtml("Ajax", "getChkList")
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Hesap Kodları</label>
                                <div class="col-md-10 col-xs-10">
                                    @bhkData.ToRenderPartialViewHtml("Ajax", "getChkList")
                                </div>
                            </div>
                            @if (Model.GTBirimID > 0)
                            {

                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Durum</label>
                                    <div class="col-md-10 col-xs-10">
                                        <div class="make-switch" data-on-label="Aktif" data-off-label="Pasif" data-on="success" data-off="danger">
                                            <input type="checkbox" value="true" name="IsAktif" class="toggle" @Model.IsAktif.ToChecked() />
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-reply"></i>Geri Dön</a>
                    <button class="btn btn-primary pull-right"><i class="fa fa-save"></i>Kaydet</button>
                </div>
            </div>
        </div>
    </form>
</div>
<script>

    $(function () {
        var model = '@Html.Raw(Json.Encode(mmMessage))';
        validateControl(model);
    });
</script>

