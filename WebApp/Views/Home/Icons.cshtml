                    <p><i class="fa fa-camera-retro fa-2x" aria-hidden="true"></i> fa-2x</p>
                    <p><i class="fa fa-camera-retro fa-3x" aria-hidden="true"></i> fa-3x</p>
                    <p><i class="fa fa-camera-retro fa-4x" aria-hidden="true"></i> fa-4x</p>
